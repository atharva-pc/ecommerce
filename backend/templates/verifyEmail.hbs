<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Your ArtVPP Account</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0d0d0d;
      font-family: 'DM Sans', sans-serif;
      color: #1a1a1a;
      padding: 40px 16px;
    }

    .wrapper {
      max-width: 560px;
      margin: 0 auto;
    }

    /* ── Hero card ── */
    .card {
      background: #fff;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.45);
    }

    /* ── Header gradient band ── */
    .header {
      background: linear-gradient(135deg, #c0396b 0%, #e8522a 45%, #f5a623 100%);
      padding: 48px 40px 56px;
      position: relative;
      overflow: hidden;
    }

    /* Decorative paint-stroke blobs */
    .header::before {
      content: '';
      position: absolute;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
      top: -80px;
      right: -60px;
    }

    .header::after {
      content: '';
      position: absolute;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.06);
      bottom: 20px;
      left: -40px;
    }

    .logo-wrap {
      display: flex;
      align-items: center;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .logo-img {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
      object-fit: cover;
    }

    /* Fallback text logo if image doesn't load */
    .logo-text {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: #fff;
      letter-spacing: -0.5px;
    }

    .logo-text span {
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      font-size: 13px;
      display: block;
      letter-spacing: 3px;
      text-transform: uppercase;
      opacity: 0.85;
      margin-top: 2px;
    }

    .header-tagline {
      position: relative;
      z-index: 1;
      margin-top: 36px;
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      color: #fff;
      line-height: 1.2;
      max-width: 320px;
    }

    .header-tagline em {
      font-style: normal;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 6px;
      padding: 2px 8px;
    }

    /* Brushstroke divider */
    .divider-svg {
      display: block;
      margin-top: -2px;
      width: 100%;
    }

    /* ── Body ── */
    .body {
      padding: 36px 40px 40px;
    }

    .greeting {
      font-size: 15px;
      color: #888;
      font-weight: 300;
      margin-bottom: 6px;
      letter-spacing: 0.5px;
    }

    .username {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      color: #1a1a1a;
      margin-bottom: 20px;
    }

    .intro {
      font-size: 15px;
      line-height: 1.75;
      color: #444;
      margin-bottom: 32px;
    }

    /* Security badge */
    .security-badge {
      background: linear-gradient(135deg, #fff8f0 0%, #fff3f8 100%);
      border-left: 4px solid #e8522a;
      border-radius: 12px;
      padding: 18px 20px;
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 36px;
    }

    .badge-icon {
      font-size: 26px;
      line-height: 1;
      flex-shrink: 0;
    }

    .badge-content strong {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #c0396b;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 5px;
    }

    .badge-content p {
      font-size: 14px;
      color: #555;
      line-height: 1.6;
    }

    /* CTA Button */
    .cta-wrap {
      text-align: center;
      margin-bottom: 30px;
    }

    .cta-btn {
      display: inline-block;
      background: linear-gradient(135deg, #c0396b 0%, #e8522a 60%, #f5a623 100%);
      color: #fff !important;
      text-decoration: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 500;
      letter-spacing: 0.5px;
      padding: 17px 52px;
      border-radius: 50px;
      box-shadow: 0 12px 32px rgba(232, 82, 42, 0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .cta-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(232, 82, 42, 0.45);
    }

    /* Expiry note */
    .expiry {
      text-align: center;
      font-size: 13px;
      color: #aaa;
      margin-bottom: 30px;
    }

    .expiry strong {
      color: #e8522a;
    }

    /* Separator */
    .sep {
      border: none;
      border-top: 1px solid #f0f0f0;
      margin: 0 0 28px;
    }

    /* Ignore note */
    .ignore-note {
      font-size: 13px;
      color: #bbb;
      line-height: 1.7;
      background: #fafafa;
      border-radius: 10px;
      padding: 16px 18px;
      margin-bottom: 32px;
    }

    /* Sign-off */
    .signoff {
      font-size: 14px;
      color: #666;
      line-height: 1.8;
    }

    .signoff strong {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: #1a1a1a;
      margin-top: 4px;
    }

    /* ── Footer ── */
    .footer {
      text-align: center;
      margin-top: 28px;
      font-size: 12px;
      color: #555;
      letter-spacing: 0.3px;
    }

    .footer a {
      color: #f5a623;
      text-decoration: none;
    }

    /* Paint dots decoration */
    .paint-dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-top: 16px;
    }

    .paint-dots span {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      opacity: 0.6;
    }
  </style>
</head>

<body>
  <!-- Hidden preview text for email clients -->
  <div style="display:none;font-size:1px;color:#333333;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;">
    Please verify your email address to complete your ArtVPP account setup and unlock creative tools.
  </div>
  <div class="wrapper">
    <div class="card">

      <!-- Header -->
      <div class="header">
        <div class="logo-wrap">
          <img src="cid:logo" alt="ArtVPP" class="logo-img" onerror="this.style.display='none'" />
          <div class="logo-text">
            ArtVPP
            <span>Creative Studio</span>
          </div>
        </div>
        <div class="header-tagline">
          Welcome to your<br /><em>creative</em> journey ✦
        </div>
      </div>

      <!-- Wave divider -->
      <svg class="divider-svg" viewBox="0 0 560 40" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,0 C140,40 420,0 560,30 L560,0 Z" fill="url(#grad)" />
        <defs>
          <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#c0396b" />
            <stop offset="50%" style="stop-color:#e8522a" />
            <stop offset="100%" style="stop-color:#f5a623" />
          </linearGradient>
        </defs>
      </svg>

      <!-- Body -->
      <div class="body">

        <p class="greeting">Hello there,</p>
        <h2 class="username">{{username}} 👋</h2>

        <p class="intro">
          We're absolutely thrilled to have you join the <strong>ArtVPP</strong> community!
          You're now one step away from unlocking a world of creative tools, curated artwork,
          and exclusive features. Just verify your email to get started.
        </p>

        <!-- Security note -->
        <div class="security-badge">
          <div class="badge-icon">🛡️</div>
          <div class="badge-content">
            <strong>Security Check</strong>
            <p>Verifying your email adds an extra layer of security and gives you full access to all ArtVPP features —
              including exclusive drops and creator tools.</p>
          </div>
        </div>

        <!-- CTA -->
        <div class="cta-wrap">
          <a href="{{verificationUrl}}" class="cta-btn">✦ Verify My Account</a>
        </div>

        <p class="expiry">🕐 This link expires in <strong>24 hours</strong> — don't miss out!</p>

        <hr class="sep" />

        <p class="ignore-note">
          🔒 Didn't sign up for ArtVPP? No worries — you can safely ignore this email. Your inbox is safe and no action
          is required.
        </p>

        <div class="signoff">
          With creativity &amp; care,
          <strong>Team ArtVPP 🎨</strong>
        </div>

      </div><!-- /body -->
    </div><!-- /card -->

    <!-- Footer -->
    <div class="footer">
      <p>© {{year}} ArtVPP · All rights reserved</p>
      <p style="margin-top:6px;">
        <a href="#">Unsubscribe</a> &nbsp;·&nbsp;
        <a href="#">Privacy Policy</a> &nbsp;·&nbsp;
        <a href="#">Help Center</a>
      </p>
      <div class="paint-dots">
        <span style="background:#c0396b;"></span>
        <span style="background:#e8522a;"></span>
        <span style="background:#f5a623;"></span>
        <span style="background:#9b59b6;"></span>
        <span style="background:#3498db;"></span>
      </div>
    </div>

  </div>
</body>

</html>