# Production environment template for Vercel
# Copy each key/value into Vercel Project Settings -> Environment Variables.

# =============================
# Server
# =============================
NODE_ENV=production
PORT=5000

# =============================
# Database
# =============================
MONGO_URI=__SET_MONGODB_CONNECTION_STRING__

# =============================
# JWT
# =============================
JWT_ACCESS_SECRET=__SET_LONG_RANDOM_SECRET__
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=__SET_LONG_RANDOM_SECRET__
JWT_REFRESH_EXPIRES=7d

# =============================
# Frontend + CORS
# =============================
CLIENT_URL=https://artvpp.vercel.app
MOBILE_APP_URL=

# =============================
# Google OAuth
# =============================
GOOGLE_CLIENT_ID=__SET_GOOGLE_CLIENT_ID__
GOOGLE_CLIENT_SECRET=__SET_GOOGLE_CLIENT_SECRET__

# =============================
# SMTP Email
# =============================
MAIL_USER=__SET_SMTP_EMAIL__
MAIL_PASS=__SET_SMTP_APP_PASSWORD__

# =============================
# Cloudinary
# =============================
CLOUDINARY_CLOUD_NAME=__SET_CLOUDINARY_CLOUD_NAME__
CLOUDINARY_API_KEY=__SET_CLOUDINARY_API_KEY__
CLOUDINARY_API_SECRET=__SET_CLOUDINARY_API_SECRET__

# =============================
# Razorpay
# =============================
RAZORPAY_KEY_ID=__SET_RAZORPAY_KEY_ID__
RAZORPAY_KEY_SECRET=__SET_RAZORPAY_KEY_SECRET__

# =============================
# Frontend (Vite)
# =============================
# Keep relative to use same-domain API routing on Vercel.
VITE_API_URL=/api/v1
VITE_RAZORPAY_KEY_ID=__SET_RAZORPAY_KEY_ID__
VITE_LAUNCH_MODE=false

